\name{suest-package}
\alias{suest-package}
\docType{package}
\title{Seemingly Unrelated Estimation for Model Comparisons}
\description{
The \pkg{suest} package combines two separately fitted regression models with
a joint model-robust covariance matrix and integrates with
\pkg{marginaleffects} for cross-model comparisons of predictions and effects.
}
\references{
Mize, T. D., Doan, L., and Long, J. S. (2019).
A General Framework for Comparing Predictions and Marginal Effects Across
Models. \emph{Sociological Methodology}, 49(1), 152--189.
doi:10.1177/0081175019852763.
}
